{
  "id": null,
  "uid": "movie-platform-overview",
  "title": "Movie Platform — Overview",
  "tags": ["movie-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Bot updates / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(bot_updates_total[5m])",
          "legendFormat": "updates/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Movies delivered / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(bot_movies_sent_total[5m])",
          "legendFormat": "movies/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Bot errors / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(bot_errors_total[5m])",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "API requests / sec (by status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "API request latency (p95, highr)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latency (s)",
          "refId": "A"
        }
      ]
    }
  ]
}
