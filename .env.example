BOT_TOKEN=
STORAGE_CHANNEL_ID=
OWNER_ID=
# From my.telegram.org — only needed to run scripts/backfill_channels.py
# (a one-off userbot script that reads a channel's full history, which the
# Bot API itself cannot do). Not read by the bot/API/admin-panel processes.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Comma-separated public channel usernames (no "@") the bot auto-relays new
# video posts from into the storage channel for parsing, once added there
# as admin — e.g. SOURCE_CHANNELS=JEKIANIME,JEKIKINO,NUR1Kkino
SOURCE_CHANNELS=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-side port docker-compose.yml publishes Postgres on (127.0.0.1 only).
# Every service inside the compose network still talks to Postgres over
# POSTGRES_HOST=postgres/5432 above regardless — this only matters for
# host-shell tools (psql, scripts/backup.sh) and only needs to change if
# 5432 is already taken by something else on the machine. Leave unset to
# keep the default 5432.
POSTGRES_HOST_PORT=
POSTGRES_USER=movie
POSTGRES_PASSWORD=
POSTGRES_DB=movie_platform
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=
# Comma-separated web panel origin(s) allowed to call the API cross-origin
# in production, e.g. https://panel.domain.uz — ignored (all origins are
# allowed) while DEBUG=true.
CORS_ORIGINS=
DEBUG=false
ENVIRONMENT=production
SENTRY_DSN=

# --- Caption parser AI fallback (both optional — regex-only works fine
# without either; only useful once you're relaying real channel posts
# through auto-ingest and want messier captions resolved too) ---
# Ollama running on the same host as `docker compose` — the bot service
# runs with `network_mode: host` specifically so it can reach this at
# 127.0.0.1 without Ollama itself ever being exposed beyond localhost. If
# this server has no local Ollama, just leave it blank; nothing breaks,
# the AI stage simply never activates.
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3:8b
# Anthropic API — tried only if OLLAMA_BASE_URL is unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Only needed if you're also running the web admin panel (not the
# bot-only deploy — see README's "Bot-only" quick-start) ---
# The admin panel's own public URL for the browser to call the API at,
# e.g. https://api.domain.uz. Defaults to http://localhost:8000 (fine for
# same-machine/dev use only).
NEXT_PUBLIC_API_URL=
# Only read if you start the "monitoring" profile (Prometheus+Grafana) —
# change this from the default before exposing Grafana at all.
GRAFANA_ADMIN_PASSWORD=
